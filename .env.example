# Lucho — Environment Configuration
# Copy this file to .env and fill in the values.

# ---- Application ----
APP_NAME=Lucho
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=DEBUG

# ---- Database (PostgreSQL + pgvector) ----
DATABASE_URL=postgresql+asyncpg://lucho:lucho@db:5432/lucho

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- MinIO ----
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=lucho
MINIO_SECURE=false

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=

# ---- Anthropic (Claude) ----
ANTHROPIC_API_KEY=
ANTHROPIC_HAIKU_MODEL=claude-3-5-haiku-latest
ANTHROPIC_SONNET_MODEL=claude-3-5-sonnet-latest

# ---- OpenAI (Whisper) ----
OPENAI_API_KEY=
