# Lucho — Environment Configuration
# Copy this file to .env and fill in the values.

# ---- Application ----
APP_NAME=Lucho
DEBUG=true
LOG_LEVEL=DEBUG

# ---- Database (PostgreSQL) ----
# Development: localhost. Production: db (Docker service name)
DATABASE_URL=postgresql+asyncpg://postgres:changeme@localhost:5433/lucho

# ---- Redis ----
# Development: localhost. Production: redis (Docker service name)
REDIS_URL=redis://localhost:6379/0

# ---- MinIO ----
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=lucho
MINIO_SECURE=false

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=

# ---- WhatsApp Cloud API (Meta) ----
# From Meta Developers: https://developers.facebook.com/
# App Dashboard → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v22.0

# ---- LLM Provider (anthropic | deepseek) ----
LLM_PROVIDER=deepseek

# ---- Anthropic (Claude) ----
ANTHROPIC_API_KEY=
ANTHROPIC_HAIKU_MODEL=claude-3-5-haiku-latest
ANTHROPIC_SONNET_MODEL=claude-3-5-sonnet-latest

# ---- DeepSeek ----
DEEPSEEK_API_KEY=
DEEPSEEK_ROUTER_MODEL=deepseek-chat
DEEPSEEK_EXTRACTOR_MODEL=deepseek-chat

# ---- OpenAI (Whisper + Embeddings) ----
OPENAI_API_KEY=
EMBEDDING_PROVIDER=none  # "openai" | "local" | "none"
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
